[Unit]
Description=OSPiSharp sprinkler controller
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/pi/OSPiSharp
ExecStart=/home/pi/OSPiSharp/OSPi.Web
Environment=ASPNETCORE_URLS=http://0.0.0.0:80
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=DOTNET_CLI_TELEMETRY_OPTOUT=1
Restart=always
RestartSec=5
KillSignal=SIGINT
SyslogIdentifier=ospisharp

[Install]
WantedBy=multi-user.target
