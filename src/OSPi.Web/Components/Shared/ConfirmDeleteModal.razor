@*
    Bootstrap confirmation modal. Render it always; toggle with Visible. Confirm/Cancel
    raise callbacks the parent handles.
*@

@if (Visible)
{
    <div class="modal fade show" style="display: block;" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="OnCancel"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">@Message</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="OnCancel">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="OnConfirm">@ConfirmText</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter] public bool Visible { get; set; }

    [Parameter] public string Title { get; set; } = "Confirm";

    [Parameter] public string Message { get; set; } = "Are you sure?";

    [Parameter] public string ConfirmText { get; set; } = "Delete";

    [Parameter] public EventCallback OnConfirm { get; set; }

    [Parameter] public EventCallback OnCancel { get; set; }
}
