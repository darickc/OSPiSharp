@*
    Confirmation dialog. Render it always; toggle with Visible. Confirm/Cancel raise
    callbacks the parent handles. Wraps MudDialog (inline, requires MudDialogProvider).
*@

<MudDialog Visible="Visible" VisibleChanged="OnVisibleChanged" Options="_options">
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>@Message</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="OnCancel">Cancel</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="OnConfirm">@ConfirmText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private readonly DialogOptions _options = new() { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };

    [Parameter] public bool Visible { get; set; }

    [Parameter] public string Title { get; set; } = "Confirm";

    [Parameter] public string Message { get; set; } = "Are you sure?";

    [Parameter] public string ConfirmText { get; set; } = "Delete";

    [Parameter] public EventCallback OnConfirm { get; set; }

    [Parameter] public EventCallback OnCancel { get; set; }

    // The dialog can close itself (backdrop/escape); keep the parent's Visible in sync by
    // treating any close as a cancel.
    private Task OnVisibleChanged(bool visible) =>
        visible ? Task.CompletedTask : OnCancel.InvokeAsync();
}
