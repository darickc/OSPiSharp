@*
    Save / Cancel button bar shared by every edit form. The Save button shows a spinner
    and disables both buttons while Busy is true.
*@

<MudStack Row="true" Spacing="2" Class="mt-4" AlignItems="AlignItems.Center">
    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
               Disabled="Busy">
        @if (Busy)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
        }
        @SaveText
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="Busy" OnClick="OnCancel">
        @CancelText
    </MudButton>
    @ChildContent
</MudStack>

@code {
    /// <summary>When true, both buttons are disabled and the Save button shows a spinner.</summary>
    [Parameter] public bool Busy { get; set; }

    /// <summary>Invoked when the Cancel button is clicked.</summary>
    [Parameter] public EventCallback OnCancel { get; set; }

    [Parameter] public string SaveText { get; set; } = "Save";

    [Parameter] public string CancelText { get; set; } = "Cancel";

    /// <summary>Optional extra controls rendered to the right of Cancel.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
