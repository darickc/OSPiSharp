@*
    Generic enum dropdown bound via @bind-Value. Labels default to the enum member name;
    pass LabelFor for friendlier text. Wraps MudSelect.
*@
@typeparam TEnum where TEnum : struct, Enum

<MudSelect T="TEnum" Value="Value" ValueChanged="OnChanged" Disabled="Disabled"
           Label="@Label" Dense="true" Margin="Margin.Dense" Variant="Variant.Outlined"
           Class="@CssClass">
    @foreach (var item in Enum.GetValues<TEnum>())
    {
        <MudSelectItem T="TEnum" Value="item">@LabelOf(item)</MudSelectItem>
    }
</MudSelect>

@code {
    [Parameter] public TEnum Value { get; set; }

    [Parameter] public EventCallback<TEnum> ValueChanged { get; set; }

    /// <summary>Optional mapping from enum member to display text.</summary>
    [Parameter] public Func<TEnum, string>? LabelFor { get; set; }

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public string? CssClass { get; set; }

    /// <summary>Optional floating label.</summary>
    [Parameter] public string? Label { get; set; }

    private string LabelOf(TEnum value) => LabelFor?.Invoke(value) ?? value.ToString();

    private async Task OnChanged(TEnum parsed)
    {
        Value = parsed;
        await ValueChanged.InvokeAsync(parsed);
    }
}
