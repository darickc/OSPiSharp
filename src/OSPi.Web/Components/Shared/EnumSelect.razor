@*
    Generic <select> bound to an enum value. Supports @bind-Value. Labels default to
    the enum member name; pass LabelFor to supply friendlier text.
*@
@typeparam TEnum where TEnum : struct, Enum

<select class="form-select @CssClass" value="@Value.ToString()" @onchange="OnChanged" disabled="@Disabled">
    @foreach (var item in Enum.GetValues<TEnum>())
    {
        <option value="@item.ToString()" selected="@item.Equals(Value)">@LabelOf(item)</option>
    }
</select>

@code {
    [Parameter] public TEnum Value { get; set; }

    [Parameter] public EventCallback<TEnum> ValueChanged { get; set; }

    /// <summary>Optional mapping from enum member to display text.</summary>
    [Parameter] public Func<TEnum, string>? LabelFor { get; set; }

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public string? CssClass { get; set; }

    private string LabelOf(TEnum value) => LabelFor?.Invoke(value) ?? value.ToString();

    private async Task OnChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<TEnum>(e.Value?.ToString(), out var parsed))
        {
            Value = parsed;
            await ValueChanged.InvokeAsync(parsed);
        }
    }
}
