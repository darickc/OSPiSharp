@*
    Time picker bound to a minute-of-day integer (0..1439). Wraps MudTimePicker.
*@

<MudTimePicker Time="_time" TimeChanged="OnTimeChanged" Margin="Margin.Dense"
               Variant="Variant.Outlined" Label="@Label" Class="@CssClass" Style="@Style" />

@code {
    [Parameter] public int Value { get; set; }

    [Parameter] public EventCallback<int> ValueChanged { get; set; }

    [Parameter] public string? CssClass { get; set; }

    [Parameter] public string? Style { get; set; }

    [Parameter] public string? Label { get; set; }

    private TimeSpan? _time;

    protected override void OnParametersSet() =>
        _time = TimeSpan.FromMinutes(Math.Clamp(Value, 0, 1439));

    private async Task OnTimeChanged(TimeSpan? time)
    {
        var minutes = time is { } ts ? (int)ts.TotalMinutes : 0;
        _time = time;
        if (minutes != Value)
        {
            Value = minutes;
            await ValueChanged.InvokeAsync(minutes);
        }
    }
}
