@*
    HTML time input bound to a minute-of-day integer (0..1439).
*@

<input type="time"
       class="form-control @CssClass"
       style="@Style"
       value="@Format(Value)"
       @onchange="OnChanged" />

@code {
    [Parameter] public int Value { get; set; }

    [Parameter] public EventCallback<int> ValueChanged { get; set; }

    [Parameter] public string? CssClass { get; set; }

    [Parameter] public string? Style { get; set; }

    private static string Format(int minuteOfDay)
    {
        minuteOfDay = Math.Clamp(minuteOfDay, 0, 1439);
        return $"{minuteOfDay / 60:D2}:{minuteOfDay % 60:D2}";
    }

    private async Task OnChanged(ChangeEventArgs e)
    {
        var text = e.Value?.ToString();
        if (!string.IsNullOrWhiteSpace(text) && TimeOnly.TryParse(text, out var time))
        {
            var minutes = (time.Hour * 60) + time.Minute;
            Value = minutes;
            await ValueChanged.InvokeAsync(minutes);
        }
        else
        {
            await ValueChanged.InvokeAsync(Value);
        }
    }
}
