@*
    Two-way bound duration input. Edits a duration in whole minutes but keeps its public
    contract in seconds (Value/ValueChanged are seconds) so callers and the downstream
    pipeline are unchanged. Wraps MudNumericField.
*@

<MudNumericField T="int" Value="_minutes" ValueChanged="OnMinutesChanged" Min="1"
                 Adornment="Adornment.End" AdornmentText="min" Margin="Margin.Dense"
                 Variant="Variant.Outlined" Label="@Label" Class="@CssClass" Style="@Style"
                 HideSpinButtons="true"
                 onfocus="this.select()" />

@code {
    [Parameter] public int Value { get; set; }

    [Parameter] public EventCallback<int> ValueChanged { get; set; }

    [Parameter] public string? CssClass { get; set; }

    [Parameter] public string? Style { get; set; }

    [Parameter] public string? Label { get; set; }

    private int _minutes = 1;

    // Round seconds to the nearest whole minute (floor at 1).
    protected override void OnParametersSet() => _minutes = Math.Max(1, (Value + 30) / 60);

    private async Task OnMinutesChanged(int minutes)
    {
        minutes = Math.Max(1, minutes);
        _minutes = minutes;
        var seconds = minutes * 60;
        if (seconds != Value)
        {
            Value = seconds;
            await ValueChanged.InvokeAsync(seconds);
        }
    }
}
