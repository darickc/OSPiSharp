@page "/config/programs"
@rendermode InteractiveServer
@using ProgramEntity = OSPi.Domain.Entities.Program
@inject IProgramRepository ProgramRepo
@inject NavigationManager Nav

<PageTitle>Programs</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1">
    <MudText Typo="Typo.h5">Programs</MudText>
    <MudButton Href="config/programs/new" Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add">New program</MudButton>
</MudStack>
<MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">Watering programs — what runs, when, and for how long.</MudText>

@if (_programs is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_programs.Count == 0)
{
    <MudAlert Severity="Severity.Normal">
        No programs yet. <MudLink Href="config/programs/new">Create one</MudLink>.
    </MudAlert>
}
else
{
    <MudTable Items="_programs" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Enabled</MudTh>
            <MudTh>Schedule</MudTh>
            <MudTh>Start times</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@(string.IsNullOrWhiteSpace(context.Name) ? "(unnamed)" : context.Name)</MudTd>
            <MudTd DataLabel="Enabled">
                @if (context.Enabled)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Enabled</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">Disabled</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Schedule">@DisplayLabels.ScheduleType(context.ScheduleType)</MudTd>
            <MudTd DataLabel="Start times" Class="mud-text-secondary">@StartTimesSummary(context)</MudTd>
            <MudTd DataLabel="Actions" Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                               Href="@($"config/programs/{context.Id}")" aria-label="Edit" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="() => AskDelete(context)" aria-label="Delete" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

<ConfirmDeleteModal Visible="_pendingDelete is not null"
                    Title="Delete program"
                    Message="@($"Delete \"{_pendingDelete?.Name}\"? This cannot be undone.")"
                    OnConfirm="ConfirmDeleteAsync"
                    OnCancel="() => _pendingDelete = null" />

@code {
    private IReadOnlyList<ProgramEntity>? _programs;
    private ProgramEntity? _pendingDelete;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _programs = await ProgramRepo.GetAllAsync();
    }

    private void AskDelete(ProgramEntity program) => _pendingDelete = program;

    private async Task ConfirmDeleteAsync()
    {
        if (_pendingDelete is not null)
        {
            await ProgramRepo.DeleteAsync(_pendingDelete.Id);
            _pendingDelete = null;
            await LoadAsync();
        }
    }

    private static string StartTimesSummary(ProgramEntity p)
    {
        if (p.StartTimeType == StartTimeType.Repeating)
        {
            var anchor = p.StartTimes.OrderBy(s => s.Slot).FirstOrDefault();
            var anchorText = anchor is null ? "—" : Describe(anchor);
            return p.RepeatCount > 0
                ? $"{anchorText}, then ×{p.RepeatCount} every {p.RepeatEveryMinutes}m"
                : anchorText;
        }

        var times = p.StartTimes.OrderBy(s => s.Slot).Select(Describe).ToList();
        return times.Count == 0 ? "—" : string.Join(", ", times);
    }

    private static string Describe(OSPi.Domain.Entities.ProgramStartTime st) => st.Kind switch
    {
        StartTimeKind.FixedMinute => $"{st.Value / 60:D2}:{st.Value % 60:D2}",
        StartTimeKind.SunriseOffset => $"Sunrise{Signed(st.Value)}",
        StartTimeKind.SunsetOffset => $"Sunset{Signed(st.Value)}",
        _ => st.Value.ToString(),
    };

    private static string Signed(int minutes) => minutes == 0 ? "" : (minutes > 0 ? $"+{minutes}m" : $"{minutes}m");
}
