@page "/config/settings"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject IControllerSettingsRepository SettingsRepo
@inject IManualRunService Run

<PageTitle>Settings</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Controller Settings</MudText>
<MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">Global, runtime-editable options. Hardware pin configuration lives in appsettings, not here.</MudText>

@if (_model is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />

        <MudGrid Style="max-width: 720px;">
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_model.WaterLevelPercent" For="@(() => _model.WaterLevelPercent)"
                                 Label="Water level (%)" Variant="Variant.Outlined" Margin="Margin.Dense"
                                 HelperText="Global scaling applied to every program duration." />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_model.StationDelaySeconds" For="@(() => _model.StationDelaySeconds)"
                                 Label="Station delay (seconds)" Variant="Variant.Outlined" Margin="Margin.Dense"
                                 HelperText="Delay inserted between sequential stations." />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudSelect T="string" @bind-Value="_model.TimeZoneId" For="@(() => _model.TimeZoneId)"
                           Label="Timezone" Variant="Variant.Outlined" Margin="Margin.Dense"
                           HelperText="@TimeZoneHelperText">
                    @foreach (var tz in TimeZones)
                    {
                        <MudSelectItem T="string" Value="@tz.Id">@tz.DisplayName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudCheckBox @bind-Value="_model.UseWeather" Label="Use weather-based adjustment" Color="Color.Primary" Dense="true" />
                <MudCheckBox @bind-Value="_model.SequentialDefault" Label="Sequential by default for new zones" Color="Color.Primary" Dense="true" />
            </MudItem>

            <MudItem xs="12">
                <MudCheckBox @bind-Value="_model.RainDelayActive" Label="Rain delay active" Color="Color.Primary" Dense="true" />
                @if (_model.RainDelayActive)
                {
                    <MudStack Row="true" Spacing="2" Class="mt-2" Style="max-width: 460px;">
                        <MudDatePicker @bind-Date="RainDate" Label="Suppress until (date)"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" />
                        <MudTimePicker @bind-Time="RainTime" Label="Time"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudStack>
                }
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_model.LocationLatitude" For="@(() => _model.LocationLatitude)"
                                 Label="Latitude" Variant="Variant.Outlined" Margin="Margin.Dense"
                                 HelperText="For sunrise/sunset start times. Leave blank if unset." />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_model.LocationLongitude" For="@(() => _model.LocationLongitude)"
                                 Label="Longitude" Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>

        <SaveCancelToolbar Busy="_busy" OnCancel="ReloadAsync" CancelText="Reset" />
    </EditForm>

    @if (_saved)
    {
        <MudAlert Severity="Severity.Success" Class="mt-3" Dense="true">Settings saved.</MudAlert>
    }
}

@code {
    private SettingsModel? _model;
    private bool _busy;
    private bool _saved;

    // Cached once; the OS tz set does not change at runtime.
    private static readonly IReadOnlyList<TimeZoneInfo> TimeZones =
        TimeZoneInfo.GetSystemTimeZones().OrderBy(z => z.BaseUtcOffset).ToList();

    // Live readout so a wrong zone is obvious: the controller's current civil time + offset.
    private string TimeZoneHelperText
    {
        get
        {
            if (_model?.TimeZoneId is { } id &&
                TimeZoneInfo.TryFindSystemTimeZoneById(id, out var tz))
            {
                var now = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, tz);
                var off = tz.GetUtcOffset(now);
                var sign = off < TimeSpan.Zero ? "-" : "+";
                return $"Controller time: {now:t} (UTC{sign}{off:hh\\:mm}). Drives schedule timing and sunrise/sunset, with DST.";
            }

            return "Select the controller's timezone. Drives schedule timing and sunrise/sunset, with DST.";
        }
    }

    // MudBlazor has no combined datetime picker, so split RainDelayUntilLocal into a date + time.
    private DateTime? RainDate
    {
        get => _model?.RainDelayUntilLocal?.Date;
        set
        {
            if (_model is null) return;
            var time = _model.RainDelayUntilLocal?.TimeOfDay ?? TimeSpan.Zero;
            _model.RainDelayUntilLocal = value is { } d ? d.Date + time : null;
        }
    }

    private TimeSpan? RainTime
    {
        get => _model?.RainDelayUntilLocal?.TimeOfDay;
        set
        {
            if (_model is null) return;
            var date = _model.RainDelayUntilLocal?.Date ?? DateTime.Today;
            _model.RainDelayUntilLocal = date + (value ?? TimeSpan.Zero);
        }
    }

    protected override Task OnInitializedAsync() => ReloadAsync();

    private async Task ReloadAsync()
    {
        var settings = await SettingsRepo.GetAsync();
        _model = SettingsModel.FromEntity(settings);
        _saved = false;
    }

    private async Task SaveAsync()
    {
        if (_model is null)
        {
            return;
        }

        _busy = true;
        try
        {
            await SettingsRepo.UpdateAsync(_model.ToEntity());
            Run.ReloadConfig(); // apply timezone / water-level / rain-delay changes live
            _saved = true;
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class SettingsModel
    {
        [Range(0, 200, ErrorMessage = "Water level must be between 0 and 200%.")]
        public int WaterLevelPercent { get; set; } = 100;

        [Range(0, 86_400, ErrorMessage = "Station delay must be between 0 and 86400 seconds.")]
        public int StationDelaySeconds { get; set; }

        [Required(ErrorMessage = "Select a timezone.")]
        public string? TimeZoneId { get; set; }

        public bool UseWeather { get; set; } = true;

        public bool SequentialDefault { get; set; } = true;

        public bool RainDelayActive { get; set; }

        public DateTime? RainDelayUntilLocal { get; set; }

        [Range(-90, 90, ErrorMessage = "Latitude must be between -90 and 90.")]
        public double? LocationLatitude { get; set; }

        [Range(-180, 180, ErrorMessage = "Longitude must be between -180 and 180.")]
        public double? LocationLongitude { get; set; }

        public static SettingsModel FromEntity(ControllerSettings s) => new()
        {
            WaterLevelPercent = s.WaterLevelPercent,
            StationDelaySeconds = s.StationDelaySeconds,
            TimeZoneId = s.TimeZoneId,
            UseWeather = s.UseWeather,
            SequentialDefault = s.SequentialDefault,
            RainDelayActive = s.RainDelayUntil is not null,
            RainDelayUntilLocal = s.RainDelayUntil?.LocalDateTime,
            LocationLatitude = s.LocationLatitude,
            LocationLongitude = s.LocationLongitude,
        };

        public ControllerSettings ToEntity()
        {
            DateTimeOffset? rainDelay = null;
            if (RainDelayActive && RainDelayUntilLocal is { } local)
            {
                rainDelay = new DateTimeOffset(local, TimeZoneInfo.Local.GetUtcOffset(local));
            }

            return new ControllerSettings
            {
                Id = 1,
                WaterLevelPercent = WaterLevelPercent,
                StationDelaySeconds = StationDelaySeconds,
                TimeZoneId = TimeZoneId,
                UseWeather = UseWeather,
                SequentialDefault = SequentialDefault,
                RainDelayUntil = rainDelay,
                LocationLatitude = LocationLatitude,
                LocationLongitude = LocationLongitude,
            };
        }
    }
}
