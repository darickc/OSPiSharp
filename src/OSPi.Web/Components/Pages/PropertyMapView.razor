@page "/map"
@rendermode InteractiveServer
@inherits SnapshotComponentBase
@implements IAsyncDisposable
@inject IPropertyMapRepository Maps
@inject IZoneRepository ZoneRepo
@inject IManualRunService ManualRun
@inject IJSRuntime JS

<PageTitle>Property Map</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Property Map</MudText>

@if (_map is null)
{
    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
}
else if (string.IsNullOrEmpty(_map.ImageHash))
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No property map yet. <MudLink Href="config/property-map">Upload one and place zone pins</MudLink> to control zones from the map.
    </MudAlert>
}
else
{
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap">
        <MudText Typo="Typo.caption" Class="mud-text-secondary">Tap a pin to run or stop that zone. Pinch or scroll to zoom, drag to pan.</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@(() => ManualRun.StopAll())"
                   StartIcon="@Icons.Material.Filled.Stop">Stop all</MudButton>
    </MudStack>

    @if (_map.Markers.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-3">
            This map has no pins yet. <MudLink Href="config/property-map">Add some</MudLink>.
        </MudAlert>
    }

    <div class="map-stage" style="display:flex; justify-content:center; align-items:flex-start; overflow:hidden;">
        <div @ref="_containerEl" style="@ContainerStyle">
            <div data-map-content style="position:absolute; inset:0; width:100%; height:100%; transform-origin:0 0;">
                <img src="@ImageUrl" alt="Property map"
                     style="width:100%; height:100%; display:block; object-fit:fill; border-radius:4px;" />
                @foreach (var m in _map.Markers)
                {
                    var bit = BitFor(m.ZoneId);
                    var status = StatusForBit(bit);
                    <div role="button" title="@PinTitle(m.ZoneId, status)" style="@PinStyle(m, status)"
                         @onclick="@(() => OpenDialog(bit))">
                        @(bit + 1)
                    </div>
                }
            </div>
        </div>
    </div>

    <ZoneRunModal Visible="_dialogBit is not null"
                  ZoneName="@ZoneNameForBit(_dialogBit ?? -1)"
                  IsActive="@(DialogZone is { } dz && (dz.On || dz.Queued || dz.Paused))"
                  StateLabel="@(DialogZone is { } dz2 ? StateLabel(dz2) : string.Empty)"
                  OnRun="RunZoneFromDialog"
                  OnStop="StopZoneFromDialog"
                  OnCancel="@(() => _dialogBit = null)" />
}

@code {
    private PropertyMap? _map;
    private Dictionary<int, int> _bitByZoneId = new();
    private Dictionary<int, string> _nameByZoneId = new();

    // Hardware bit of the zone whose run/stop dialog is open, or null when closed.
    private int? _dialogBit;

    private ElementReference _containerEl;
    private IJSObjectReference? _module;
    private bool _panZoomReady;

    protected override async Task OnInitializedAsync()
    {
        var zones = await ZoneRepo.GetAllAsync();
        _bitByZoneId = zones.ToDictionary(z => z.Id, z => z.HardwareBit);
        _nameByZoneId = zones.ToDictionary(
            z => z.Id,
            z => string.IsNullOrWhiteSpace(z.Name) ? $"Zone {z.HardwareBit + 1}" : z.Name);

        _map = await Maps.GetAsync();
    }

    // Attach pan/zoom once the map image (and its container @ref) has rendered.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_panZoomReady && _map is not null && !string.IsNullOrEmpty(_map.ImageHash))
        {
            _panZoomReady = true;
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Pages/PropertyMapView.razor.js");
            await _module.InvokeVoidAsync("init", _containerEl,
                (double)_map.ImageWidth / _map.ImageHeight);
        }
    }

    private string ImageUrl => $"/property-map/image?v={_map!.ImageHash}";

    // Pre-JS fallback: full-width box at the image's aspect ratio. The pan/zoom module
    // overrides width/height with the fitted px size once it loads (explicit px wins).
    private string ContainerStyle =>
        $"position:relative; width:100%; aspect-ratio:{_map!.ImageWidth} / {_map.ImageHeight}; " +
        "overflow:hidden; touch-action:none; margin:auto;";

    private int BitFor(int zoneId) => _bitByZoneId.GetValueOrDefault(zoneId, -1);

    // Live status of the dialog's zone, re-resolved each render so the dialog reflects
    // real-time engine updates (e.g. a zone finishing while open).
    private ZoneStatus? DialogZone =>
        _dialogBit is { } bit ? Snapshot?.Zones.FirstOrDefault(z => z.ZoneId == bit) : null;

    private void OpenDialog(int bit)
    {
        if (bit >= 0) _dialogBit = bit;
    }

    private void RunZoneFromDialog(int seconds)
    {
        if (_dialogBit is { } bit && seconds > 0) ManualRun.RunZoneTimed(bit, seconds);
        _dialogBit = null;
    }

    private void StopZoneFromDialog()
    {
        // CancelZone: drops the queued/running item and clears any manual override.
        if (_dialogBit is { } bit) ManualRun.StopZone(bit);
        _dialogBit = null;
    }

    private string ZoneNameForBit(int bit)
    {
        foreach (var (zoneId, name) in _nameByZoneId)
        {
            if (_bitByZoneId.GetValueOrDefault(zoneId, -1) == bit) return name;
        }
        return $"Zone {bit + 1}";
    }

    private static string StateLabel(ZoneStatus z) =>
        z.Paused ? "PAUSED" : z.On ? "ON" : z.Queued ? "QUEUED" : "OFF";

    public async ValueTask DisposeAsync()
    {
        Dispose(); // base: unsubscribe from the snapshot feed
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _containerEl);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone; nothing to clean up.
            }
        }
    }

    private ZoneStatus? StatusForBit(int bit)
    {
        if (bit < 0 || Snapshot is null)
        {
            return null;
        }

        foreach (var z in Snapshot.Zones)
        {
            if (z.ZoneId == bit)
            {
                return z;
            }
        }

        return null;
    }

    private string PinTitle(int zoneId, ZoneStatus? status)
    {
        var name = _nameByZoneId.GetValueOrDefault(zoneId, "Zone");
        var state = status is null ? "off" : status.On ? "running" : status.Queued ? "queued" : "off";
        return $"{name} — {state}";
    }

    private static string PinStyle(MapMarker m, ZoneStatus? status)
    {
        var (bg, ring) = status switch
        {
            { On: true } => ("#43a047", "#a5d6a7"),
            { Queued: true } => ("#fb8c00", "#ffcc80"),
            _ => ("rgba(40,40,55,.85)", "rgba(255,255,255,.5)"),
        };

        return $"position:absolute; left:{Pct(m.X)}; top:{Pct(m.Y)}; transform:translate(-50%,-50%); " +
               "cursor:pointer; min-width:1.7rem; height:1.7rem; padding:0 .35rem; border-radius:.85rem; " +
               $"background:{bg}; color:#fff; font-size:.8rem; font-weight:600; line-height:1.7rem; " +
               $"text-align:center; box-shadow:0 0 0 2px {ring}; white-space:nowrap; user-select:none;";
    }

    private static string Pct(double v) => $"{(v * 100).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}%";
}
