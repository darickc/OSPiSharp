@page "/log"
@rendermode InteractiveServer
@inject IRunLogRepository RunLogRepo

<PageTitle>History</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-1">
    <MudText Typo="Typo.h5">History</MudText>
    <MudButton Variant="Variant.Outlined" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Refresh" OnClick="LoadAsync">Refresh</MudButton>
</MudStack>
<MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">Recent completed zone runs (most recent first).</MudText>

@if (_entries is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else if (_entries.Count == 0)
{
    <MudAlert Severity="Severity.Normal">No runs recorded yet.</MudAlert>
}
else
{
    <MudTable Items="_entries" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Zone</MudTh>
            <MudTh>Program</MudTh>
            <MudTh>Started</MudTh>
            <MudTh Style="text-align:right">Duration</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Zone">@ZoneName(context)</MudTd>
            <MudTd DataLabel="Program">@ProgramName(context)</MudTd>
            <MudTd DataLabel="Started">@context.StartTime.ToLocalTime().ToString("g")</MudTd>
            <MudTd DataLabel="Duration" Style="text-align:right">@Fmt(context.DurationSeconds)</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private IReadOnlyList<RunLogEntry>? _entries;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _entries = await RunLogRepo.GetRecentAsync(100);
    }

    private static string ZoneName(RunLogEntry e) =>
        string.IsNullOrWhiteSpace(e.Zone?.Name) ? $"Zone {e.ZoneId}" : e.Zone!.Name;

    private static string ProgramName(RunLogEntry e) =>
        e.ProgramId is null ? "Manual" : e.Program?.Name ?? "(deleted program)";

    private static string Fmt(int seconds) => $"{seconds / 60:D2}:{seconds % 60:D2}";
}
