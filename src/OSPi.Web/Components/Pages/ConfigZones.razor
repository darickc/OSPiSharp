@page "/config/zones"
@rendermode InteractiveServer
@inject IZoneRepository ZoneRepo
@inject NavigationManager Nav

<PageTitle>Zones</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Zones</MudText>
<MudText Typo="Typo.body2" Class="mb-4 mud-text-secondary">The 16 physical zones. Names, grouping, and bindings are editable; the hardware bit is fixed.</MudText>

@if (_zones is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudTable Items="_zones" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
        <HeaderContent>
            <MudTh>Bit</MudTh>
            <MudTh>Name</MudTh>
            <MudTh>Group</MudTh>
            <MudTh>Masters</MudTh>
            <MudTh>Flags</MudTh>
            <MudTh Style="text-align:right">Edit</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Bit">@context.HardwareBit</MudTd>
            <MudTd DataLabel="Name">@(string.IsNullOrWhiteSpace(context.Name) ? $"Zone {context.HardwareBit + 1}" : context.Name)</MudTd>
            <MudTd DataLabel="Group">@DisplayLabels.ZoneGroup(context.Group)</MudTd>
            <MudTd DataLabel="Masters">
                @if (context.BoundToMaster1)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="me-1">M1</MudChip>
                }
                @if (context.BoundToMaster2)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Class="me-1">M2</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Flags">
                @if (context.Disabled)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Class="me-1">Disabled</MudChip>
                }
                @if (context.IgnoreRain)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="me-1">Ignore rain</MudChip>
                }
                @if (context.IgnoreSensor)
                {
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="me-1">Ignore sensor</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Edit" Style="text-align:right">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                               Href="@($"config/zones/{context.Id}")" aria-label="Edit" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private IReadOnlyList<Zone>? _zones;

    protected override async Task OnInitializedAsync()
    {
        _zones = await ZoneRepo.GetAllAsync();
    }
}
