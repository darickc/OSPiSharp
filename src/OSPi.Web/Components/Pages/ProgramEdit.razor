@page "/config/programs/new"
@page "/config/programs/{Id:int}"
@rendermode InteractiveServer
@inject IProgramRepository ProgramRepo
@inject IZoneRepository ZoneRepo
@inject NavigationManager Nav

<PageTitle>@(Id is null ? "New Program" : "Edit Program")</PageTitle>

@if (_notFound)
{
    <h1>Program not found</h1>
    <a class="btn btn-outline-secondary" href="config/programs">Back to programs</a>
}
else if (_model is null || _zones is null)
{
    <p><em>Loading…</em></p>
}
else
{
    <h1>@(Id is null ? "New Program" : "Edit Program")</h1>

    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div style="max-width: 760px;">
            @* ---- Basics ---- *@
            <div class="row g-3">
                <div class="col-md-8">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="_model.Name" />
                    <ValidationMessage For="() => _model.Name" />
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <div>
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" id="enabled" @bind-Value="_model.Enabled" />
                            <label class="form-check-label" for="enabled">Enabled</label>
                        </div>
                        <div class="form-check">
                            <InputCheckbox class="form-check-input" id="useWeather" @bind-Value="_model.UseWeather" />
                            <label class="form-check-label" for="useWeather">Use weather</label>
                        </div>
                    </div>
                </div>
            </div>

            @* ---- Schedule ---- *@
            <h2 class="h5 mt-4">Schedule</h2>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Type</label>
                    <EnumSelect TEnum="ScheduleType" @bind-Value="_model.ScheduleType" LabelFor="DisplayLabels.ScheduleType" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Odd/even days</label>
                    <EnumSelect TEnum="OddEvenRestriction" @bind-Value="_model.OddEven" LabelFor="DisplayLabels.OddEven" />
                </div>
            </div>

            @switch (_model.ScheduleType)
            {
                case ScheduleType.Weekly:
                    <div class="mt-3">
                        <label class="form-label">Run on</label>
                        <WeekdayPicker @bind-Value="_model.WeekdayMask" />
                        <ValidationMessage For="() => _model.WeekdayMask" />
                    </div>
                    break;

                case ScheduleType.Interval:
                    <div class="row g-3 mt-0">
                        <div class="col-md-4">
                            <label class="form-label">Every N days</label>
                            <InputNumber class="form-control" @bind-Value="_model.IntervalDays" />
                            <ValidationMessage For="() => _model.IntervalDays" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Remainder</label>
                            <InputNumber class="form-control" @bind-Value="_model.IntervalRemainder" />
                            <ValidationMessage For="() => _model.IntervalRemainder" />
                            <div class="form-text">Runs when epoch-day % N == remainder.</div>
                        </div>
                    </div>
                    break;

                case ScheduleType.Monthly:
                    <div class="row g-3 mt-0">
                        <div class="col-md-4">
                            <label class="form-label">Day of month</label>
                            <InputNumber class="form-control" @bind-Value="_model.MonthlyDay" disabled="@_model.MonthlyLastDay" />
                            <ValidationMessage For="() => _model.MonthlyDay" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end">
                            <div class="form-check mb-2">
                                <InputCheckbox class="form-check-input" id="lastDay" @bind-Value="_model.MonthlyLastDay" />
                                <label class="form-check-label" for="lastDay">Last day of month</label>
                            </div>
                        </div>
                    </div>
                    break;

                case ScheduleType.SingleRun:
                    <div class="row g-3 mt-0">
                        <div class="col-md-4">
                            <label class="form-label">Run date</label>
                            <InputDate class="form-control" @bind-Value="_model.SingleRunDate" />
                            <ValidationMessage For="() => _model.SingleRunDate" />
                        </div>
                    </div>
                    break;
            }

            @* ---- Date-range gate ---- *@
            <div class="form-check mt-3">
                <InputCheckbox class="form-check-input" id="dateRange" @bind-Value="_model.DateRangeEnabled" />
                <label class="form-check-label" for="dateRange">Only run within a date range</label>
            </div>
            @if (_model.DateRangeEnabled)
            {
                <div class="row g-3 mt-0">
                    <div class="col-md-3">
                        <label class="form-label">Start month</label>
                        <InputNumber class="form-control" @bind-Value="_model.DateRangeStartMonth" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Start day</label>
                        <InputNumber class="form-control" @bind-Value="_model.DateRangeStartDay" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">End month</label>
                        <InputNumber class="form-control" @bind-Value="_model.DateRangeEndMonth" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">End day</label>
                        <InputNumber class="form-control" @bind-Value="_model.DateRangeEndDay" />
                    </div>
                </div>
            }

            @* ---- Start times ---- *@
            <h2 class="h5 mt-4">Start times</h2>
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Mode</label>
                    <EnumSelect TEnum="StartTimeType" @bind-Value="_model.StartTimeType" />
                </div>
            </div>

            @if (_model.StartTimeType == StartTimeType.Repeating)
            {
                <div class="mt-3">
                    @if (_model.StartTimes.Count > 0)
                    {
                        @StartTimeRowEditor(_model.StartTimes[0], 0, allowRemove: false)
                    }
                    <div class="row g-3 mt-0">
                        <div class="col-md-4">
                            <label class="form-label">Repeat count</label>
                            <InputNumber class="form-control" @bind-Value="_model.RepeatCount" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Every (minutes)</label>
                            <InputNumber class="form-control" @bind-Value="_model.RepeatEveryMinutes" />
                            <ValidationMessage For="() => _model.RepeatEveryMinutes" />
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="mt-2">
                    @for (var i = 0; i < _model.StartTimes.Count; i++)
                    {
                        @StartTimeRowEditor(_model.StartTimes[i], i, allowRemove: true)
                    }
                    <button type="button" class="btn btn-sm btn-outline-secondary mt-2"
                            disabled="@(_model.StartTimes.Count >= ProgramEditModel.MaxStartTimes)"
                            @onclick="AddStartTime">
                        + Add start time
                    </button>
                </div>
            }
            <ValidationMessage For="() => _model.StartTimes" />

            @* ---- Zones ---- *@
            <h2 class="h5 mt-4">Zones</h2>
            <ValidationMessage For="() => _model.ZoneDurations" />
            @if (_model.ZoneDurations.Count > 0)
            {
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Zone</th>
                            <th style="width: 8rem;">Duration</th>
                            <th style="width: 7rem;">Run order</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _model.ZoneDurations.OrderBy(d => d.RunOrder).ToList())
                        {
                            <tr>
                                <td>@ZoneName(row.ZoneId)</td>
                                <td><DurationInput @bind-Value="row.DurationSeconds" /></td>
                                <td><InputNumber class="form-control" @bind-Value="row.RunOrder" /></td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveZone(row)">Remove</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            <div class="d-flex gap-2 align-items-center">
                <select class="form-select" style="max-width: 16rem;" @bind="_addZoneId">
                    <option value="0">Add a zone…</option>
                    @foreach (var zone in AvailableZones())
                    {
                        <option value="@zone.Id">@ZoneName(zone.Id)</option>
                    }
                </select>
                <button type="button" class="btn btn-outline-secondary" disabled="@(_addZoneId == 0)" @onclick="AddZone">Add</button>
            </div>

            <SaveCancelToolbar Busy="_busy" OnCancel="GoBack" />
        </div>
    </EditForm>
}

@code {
    [Parameter] public int? Id { get; set; }

    private ProgramEditModel? _model;
    private IReadOnlyList<Zone>? _zones;
    private bool _busy;
    private bool _notFound;
    private int _addZoneId;

    protected override async Task OnParametersSetAsync()
    {
        _zones = await ZoneRepo.GetAllAsync();

        if (Id is null)
        {
            _model = ProgramEditModel.NewProgram();
            return;
        }

        var program = await ProgramRepo.GetWithDetailsAsync(Id.Value);
        if (program is null)
        {
            _notFound = true;
            return;
        }

        _model = ProgramEditModel.FromEntity(program);
    }

    private RenderFragment StartTimeRowEditor(ProgramEditModel.StartTimeRow row, int index, bool allowRemove) => @<div class="row g-2 align-items-end mb-2">
        <div class="col-md-4">
            @if (index == 0)
            {
                <label class="form-label">Kind</label>
            }
            <EnumSelect TEnum="StartTimeKind" @bind-Value="row.Kind" LabelFor="DisplayLabels.StartTimeKind" />
        </div>
        <div class="col-md-4">
            @if (row.Kind == StartTimeKind.FixedMinute)
            {
                <TimeOfDayInput @bind-Value="row.MinuteOfDay" />
            }
            else
            {
                <div class="input-group">
                    <InputNumber class="form-control" @bind-Value="row.OffsetMinutes" />
                    <span class="input-group-text">min</span>
                </div>
            }
        </div>
        <div class="col-md-2">
            @if (allowRemove)
            {
                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveStartTime(row)">Remove</button>
            }
        </div>
    </div>;

    private void AddStartTime()
    {
        if (_model is not null && _model.StartTimes.Count < ProgramEditModel.MaxStartTimes)
        {
            _model.StartTimes.Add(new ProgramEditModel.StartTimeRow { Kind = StartTimeKind.FixedMinute, MinuteOfDay = 6 * 60 });
        }
    }

    private void RemoveStartTime(ProgramEditModel.StartTimeRow row) => _model?.StartTimes.Remove(row);

    private IEnumerable<Zone> AvailableZones()
    {
        if (_zones is null || _model is null)
        {
            return Enumerable.Empty<Zone>();
        }

        var used = _model.ZoneDurations.Select(d => d.ZoneId).ToHashSet();
        return _zones.Where(z => !used.Contains(z.Id));
    }

    private void AddZone()
    {
        if (_model is null || _addZoneId == 0)
        {
            return;
        }

        var nextOrder = _model.ZoneDurations.Count == 0 ? 0 : _model.ZoneDurations.Max(d => d.RunOrder) + 1;
        _model.ZoneDurations.Add(new ProgramEditModel.ZoneDurationRow
        {
            ZoneId = _addZoneId,
            DurationSeconds = 300,
            RunOrder = nextOrder,
        });
        _addZoneId = 0;
    }

    private void RemoveZone(ProgramEditModel.ZoneDurationRow row) => _model?.ZoneDurations.Remove(row);

    private string ZoneName(int zoneId)
    {
        var zone = _zones?.FirstOrDefault(z => z.Id == zoneId);
        if (zone is null)
        {
            return $"Zone {zoneId}";
        }

        return string.IsNullOrWhiteSpace(zone.Name) ? $"Zone {zone.HardwareBit + 1}" : zone.Name;
    }

    private async Task SaveAsync()
    {
        if (_model is null)
        {
            return;
        }

        _busy = true;
        try
        {
            var entity = _model.ToEntity();
            if (Id is null)
            {
                await ProgramRepo.AddAsync(entity);
            }
            else
            {
                await ProgramRepo.UpdateAsync(entity);
            }

            GoBack();
        }
        finally
        {
            _busy = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("config/programs");
}
