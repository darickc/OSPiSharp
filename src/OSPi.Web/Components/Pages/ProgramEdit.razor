@page "/config/programs/new"
@page "/config/programs/{Id:int}"
@rendermode InteractiveServer
@inject IProgramRepository ProgramRepo
@inject IZoneRepository ZoneRepo
@inject NavigationManager Nav

<PageTitle>@(Id is null ? "New Program" : "Edit Program")</PageTitle>

@if (_notFound)
{
    <MudText Typo="Typo.h5" GutterBottom="true">Program not found</MudText>
    <MudButton Href="config/programs" Variant="Variant.Outlined">Back to programs</MudButton>
}
else if (_model is null || _zones is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudText Typo="Typo.h5" GutterBottom="true">@(Id is null ? "New Program" : "Edit Program")</MudText>

    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />

        <div style="max-width: 820px;">
            @* ---- Basics ---- *@
            <MudGrid>
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="_model.Name" For="@(() => _model.Name)" Label="Name"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudCheckBox @bind-Value="_model.Enabled" Label="Enabled" Color="Color.Primary" Dense="true" />
                    <MudCheckBox @bind-Value="_model.UseWeather" Label="Use weather" Color="Color.Primary" Dense="true" />
                </MudItem>
            </MudGrid>

            @* ---- Schedule ---- *@
            <MudText Typo="Typo.h6" Class="mt-6">Schedule</MudText>
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <EnumSelect TEnum="ScheduleType" @bind-Value="_model.ScheduleType" Label="Type"
                                LabelFor="DisplayLabels.ScheduleType" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <EnumSelect TEnum="OddEvenRestriction" @bind-Value="_model.OddEven" Label="Odd/even days"
                                LabelFor="DisplayLabels.OddEven" />
                </MudItem>
            </MudGrid>

            @switch (_model.ScheduleType)
            {
                case ScheduleType.Weekly:
                    <div class="mt-3">
                        <MudText Typo="Typo.body2" Class="mb-1">Run on</MudText>
                        <WeekdayPicker @bind-Value="_model.WeekdayMask" />
                        <MudText Color="Color.Error" Typo="Typo.caption"><ValidationMessage For="() => _model.WeekdayMask" /></MudText>
                    </div>
                    break;

                case ScheduleType.Interval:
                    <MudGrid Class="mt-0">
                        <MudItem xs="12" sm="4">
                            <MudNumericField @bind-Value="_model.IntervalDays" For="@(() => _model.IntervalDays)"
                                             Label="Every N days" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField @bind-Value="_model.IntervalRemainder" For="@(() => _model.IntervalRemainder)"
                                             Label="Remainder" Variant="Variant.Outlined" Margin="Margin.Dense"
                                             HelperText="Runs when epoch-day % N == remainder." />
                        </MudItem>
                    </MudGrid>
                    break;

                case ScheduleType.Monthly:
                    <MudGrid Class="mt-0" Style="align-items: center;">
                        <MudItem xs="12" sm="4">
                            <MudNumericField @bind-Value="_model.MonthlyDay" For="@(() => _model.MonthlyDay)"
                                             Label="Day of month" Disabled="@_model.MonthlyLastDay"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudCheckBox @bind-Value="_model.MonthlyLastDay" Label="Last day of month" Color="Color.Primary" Dense="true" />
                        </MudItem>
                    </MudGrid>
                    break;

                case ScheduleType.SingleRun:
                    <MudGrid Class="mt-0">
                        <MudItem xs="12" sm="4">
                            <MudDatePicker @bind-Date="SingleRunDateTime" Label="Run date"
                                           Variant="Variant.Outlined" Margin="Margin.Dense" />
                            <MudText Color="Color.Error" Typo="Typo.caption"><ValidationMessage For="() => _model.SingleRunDate" /></MudText>
                        </MudItem>
                    </MudGrid>
                    break;
            }

            @* ---- Date-range gate ---- *@
            <MudCheckBox @bind-Value="_model.DateRangeEnabled" Label="Only run within a date range"
                         Color="Color.Primary" Dense="true" Class="mt-3" />
            @if (_model.DateRangeEnabled)
            {
                <MudGrid>
                    <MudItem xs="6" sm="3">
                        <MudNumericField @bind-Value="_model.DateRangeStartMonth" Label="Start month"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField @bind-Value="_model.DateRangeStartDay" Label="Start day"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField @bind-Value="_model.DateRangeEndMonth" Label="End month"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudNumericField @bind-Value="_model.DateRangeEndDay" Label="End day"
                                         Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            }

            @* ---- Start times ---- *@
            <MudText Typo="Typo.h6" Class="mt-6">Start times</MudText>
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <EnumSelect TEnum="StartTimeType" @bind-Value="_model.StartTimeType" Label="Mode" />
                </MudItem>
            </MudGrid>

            @if (_model.StartTimeType == StartTimeType.Repeating)
            {
                <div class="mt-2">
                    @if (_model.StartTimes.Count > 0)
                    {
                        @StartTimeRowEditor(_model.StartTimes[0], allowRemove: false)
                    }
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <MudNumericField @bind-Value="_model.RepeatCount" Label="Repeat count"
                                             Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudNumericField @bind-Value="_model.RepeatEveryMinutes" For="@(() => _model.RepeatEveryMinutes)"
                                             Label="Every (minutes)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>
                </div>
            }
            else
            {
                <div class="mt-2">
                    @foreach (var row in _model.StartTimes)
                    {
                        @StartTimeRowEditor(row, allowRemove: true)
                    }
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Class="mt-2"
                               StartIcon="@Icons.Material.Filled.Add"
                               Disabled="@(_model.StartTimes.Count >= ProgramEditModel.MaxStartTimes)"
                               OnClick="AddStartTime">
                        Add start time
                    </MudButton>
                </div>
            }
            <MudText Color="Color.Error" Typo="Typo.caption"><ValidationMessage For="() => _model.StartTimes" /></MudText>

            @* ---- Zones ---- *@
            <MudText Typo="Typo.h6" Class="mt-6">Zones</MudText>
            <MudText Typo="Typo.body2" Class="mb-2 mud-text-secondary">Drag a row by its handle to set the order zones run in.</MudText>
            <MudText Color="Color.Error" Typo="Typo.caption"><ValidationMessage For="() => _model.ZoneDurations" /></MudText>

            @if (_model.ZoneDurations.Count > 0)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                    <MudCheckBox T="bool" Value="AllSelected" ValueChanged="ToggleSelectAll" Label="Select all" Dense="true" />
                    @if (SelectedCount > 0)
                    {
                        <MudPaper Class="d-flex align-center gap-3 px-3 py-1" Elevation="0" Outlined="true">
                            <MudText Typo="Typo.body2">@SelectedCount selected</MudText>
                            <DurationInput @bind-Value="_bulkDurationSeconds" Label="Set duration" Style="max-width: 8rem;" />
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="ApplyBulkDuration">Apply to selected</MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="ClearSelection">Clear</MudButton>
                        </MudPaper>
                    }
                </MudStack>

                <MudDropContainer T="ProgramEditModel.ZoneDurationRow" @ref="_dropContainer"
                                  Items="_model.ZoneDurations"
                                  ItemsSelector="@((item, zone) => true)"
                                  ItemDropped="OnZoneDropped">
                    <ChildContent>
                        <MudDropZone T="ProgramEditModel.ZoneDurationRow" Identifier="zones" AllowReorder="true"
                                     Class="d-flex flex-column gap-2" />
                    </ChildContent>
                    <ItemRenderer Context="zone">
                        <MudPaper Class="d-flex align-center gap-3 pa-2" Elevation="1">
                            <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Class="mud-text-secondary" Style="cursor: grab;" />
                            <MudCheckBox @bind-Value="zone.Selected" Dense="true" Color="Color.Primary" />
                            <MudText Style="min-width: 9rem;">@ZoneName(zone.ZoneId)</MudText>
                            <DurationInput @bind-Value="zone.DurationSeconds" Style="max-width: 7rem;" />
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => RemoveZone(zone))" aria-label="Remove zone" />
                        </MudPaper>
                    </ItemRenderer>
                </MudDropContainer>
            }

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-3">
                <MudSelect T="int" @bind-Value="_addZoneId" Label="Add a zone…" Dense="true"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 16rem;">
                    <MudSelectItem T="int" Value="0">Add a zone…</MudSelectItem>
                    @foreach (var zone in AvailableZones())
                    {
                        <MudSelectItem T="int" Value="@zone.Id">@ZoneName(zone.Id)</MudSelectItem>
                    }
                </MudSelect>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add"
                           Disabled="@(_addZoneId == 0)" OnClick="AddZone">Add</MudButton>
            </MudStack>

            <SaveCancelToolbar Busy="_busy" OnCancel="GoBack" />
        </div>
    </EditForm>
}

@code {
    [Parameter] public int? Id { get; set; }

    private ProgramEditModel? _model;
    private IReadOnlyList<Zone>? _zones;
    private bool _busy;
    private bool _notFound;
    private int _addZoneId;
    private int _bulkDurationSeconds = 300;

    private MudDropContainer<ProgramEditModel.ZoneDurationRow>? _dropContainer;

    private int SelectedCount => _model?.ZoneDurations.Count(d => d.Selected) ?? 0;
    private bool AllSelected => _model is { ZoneDurations.Count: > 0 } && _model.ZoneDurations.All(d => d.Selected);

    // MudDatePicker binds DateTime?; the model stores DateOnly?.
    private DateTime? SingleRunDateTime
    {
        get => _model?.SingleRunDate is { } d ? d.ToDateTime(TimeOnly.MinValue) : null;
        set
        {
            if (_model is not null)
            {
                _model.SingleRunDate = value is { } dt ? DateOnly.FromDateTime(dt) : null;
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        _zones = await ZoneRepo.GetAllAsync();

        if (Id is null)
        {
            _model = ProgramEditModel.NewProgram();
            return;
        }

        var program = await ProgramRepo.GetWithDetailsAsync(Id.Value);
        if (program is null)
        {
            _notFound = true;
            return;
        }

        _model = ProgramEditModel.FromEntity(program);
    }

    // Reorder via MudDropContainer: remove + re-insert at the drop index is equivalent to
    // ProgramEditModel.MoveZone(oldIndex, newIndex) (the unit-tested reorder primitive).
    private void OnZoneDropped(MudItemDropInfo<ProgramEditModel.ZoneDurationRow> info)
    {
        if (_model is null || info.Item is null)
        {
            return;
        }

        var oldIndex = _model.ZoneDurations.IndexOf(info.Item);
        if (oldIndex < 0)
        {
            return;
        }

        var newIndex = Math.Clamp(info.IndexInZone, 0, _model.ZoneDurations.Count - 1);
        _model.MoveZone(oldIndex, newIndex);
        _dropContainer?.Refresh();
    }

    private RenderFragment StartTimeRowEditor(ProgramEditModel.StartTimeRow row, bool allowRemove) => @<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2" Style="max-width: 640px;">
        <EnumSelect TEnum="StartTimeKind" @bind-Value="row.Kind" Label="Kind" LabelFor="DisplayLabels.StartTimeKind" />
        @if (row.Kind == StartTimeKind.FixedMinute)
        {
            <TimeOfDayInput @bind-Value="row.MinuteOfDay" Label="Time" />
        }
        else
        {
            <MudNumericField @bind-Value="row.OffsetMinutes" Label="Offset" Adornment="Adornment.End"
                             AdornmentText="min" Variant="Variant.Outlined" Margin="Margin.Dense" />
        }
        @if (allowRemove)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                           OnClick="@(() => RemoveStartTime(row))" aria-label="Remove start time" />
        }
    </MudStack>;

    private void AddStartTime()
    {
        if (_model is not null && _model.StartTimes.Count < ProgramEditModel.MaxStartTimes)
        {
            _model.StartTimes.Add(new ProgramEditModel.StartTimeRow { Kind = StartTimeKind.FixedMinute, MinuteOfDay = 6 * 60 });
        }
    }

    private void RemoveStartTime(ProgramEditModel.StartTimeRow row) => _model?.StartTimes.Remove(row);

    private IEnumerable<Zone> AvailableZones()
    {
        if (_zones is null || _model is null)
        {
            return Enumerable.Empty<Zone>();
        }

        var used = _model.ZoneDurations.Select(d => d.ZoneId).ToHashSet();
        return _zones.Where(z => !used.Contains(z.Id));
    }

    private void AddZone()
    {
        if (_model is null || _addZoneId == 0)
        {
            return;
        }

        // Run order is the list position (renumbered on save), so just append.
        _model.ZoneDurations.Add(new ProgramEditModel.ZoneDurationRow
        {
            ZoneId = _addZoneId,
            DurationSeconds = 300,
        });
        _addZoneId = 0;
        _dropContainer?.Refresh();
    }

    private void RemoveZone(ProgramEditModel.ZoneDurationRow row)
    {
        _model?.ZoneDurations.Remove(row);
        _dropContainer?.Refresh();
    }

    private void ApplyBulkDuration()
    {
        _model?.ApplyDurationToSelected(_bulkDurationSeconds);
        _dropContainer?.Refresh();
    }

    private void ClearSelection()
    {
        if (_model is null)
        {
            return;
        }

        foreach (var row in _model.ZoneDurations)
        {
            row.Selected = false;
        }

        _dropContainer?.Refresh();
    }

    private void ToggleSelectAll(bool select)
    {
        if (_model is null)
        {
            return;
        }

        foreach (var row in _model.ZoneDurations)
        {
            row.Selected = select;
        }

        _dropContainer?.Refresh();
    }

    private string ZoneName(int zoneId)
    {
        var zone = _zones?.FirstOrDefault(z => z.Id == zoneId);
        if (zone is null)
        {
            return $"Zone {zoneId}";
        }

        return string.IsNullOrWhiteSpace(zone.Name) ? $"Zone {zone.HardwareBit + 1}" : zone.Name;
    }

    private async Task SaveAsync()
    {
        if (_model is null)
        {
            return;
        }

        _busy = true;
        try
        {
            var entity = _model.ToEntity();
            if (Id is null)
            {
                await ProgramRepo.AddAsync(entity);
            }
            else
            {
                await ProgramRepo.UpdateAsync(entity);
            }

            GoBack();
        }
        finally
        {
            _busy = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("config/programs");
}
