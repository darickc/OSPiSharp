@page "/"
@page "/zones"
@rendermode InteractiveServer
@inherits SnapshotComponentBase
@using ProgramEntity = OSPi.Domain.Entities.Program
@inject IManualRunService ManualRun
@inject IZoneRepository ZoneRepo
@inject IProgramRepository ProgramRepo

<PageTitle>Dashboard</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Dashboard</MudText>

@if (Snapshot is null)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        <MudText>Waiting for engine…</MudText>
    </MudStack>
}
else
{
    @if (RunningZone is { } running)
    {
        <MudPaper Class="d-flex align-center flex-wrap gap-3 pa-3 mb-3" Elevation="0" Outlined="true"
                  Style="@(RunningBannerStyle + "position: sticky; top: var(--mud-appbar-height); z-index: 3; cursor: pointer;")"
                  @onclick="@(() => OpenRunDialog(running.ZoneId))">
            <MudIcon Icon="@Icons.Material.Filled.Opacity" Size="Size.Large"
                     Color="@(running.Paused ? Color.Info : Color.Success)" />
            <MudStack Spacing="0">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Currently running</MudText>
                <MudText Typo="Typo.h6">@ZoneName(running.ZoneId)</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@ProgramLabel(running)</MudText>
            </MudStack>
            <MudSpacer />
            <MudStack Spacing="0" AlignItems="AlignItems.End">
                <MudChip T="string" Size="Size.Small" Color="@(running.Paused ? Color.Info : Color.Success)">@StateLabel(running)</MudChip>
                @if (running.SecondsRemaining is { } secs)
                {
                    <MudText Typo="Typo.h5" Style="font-variant-numeric: tabular-nums;">@Fmt(secs)</MudText>
                }
            </MudStack>
        </MudPaper>
    }

    <MudPaper Class="d-flex align-center flex-wrap gap-2 pa-2 mb-3" Elevation="0" Outlined="true">
        <MudChip T="string" Size="Size.Small" Color="@(Snapshot.Paused ? Color.Warning : Color.Success)">
            @(Snapshot.Paused ? $"Paused {Fmt(Snapshot.PauseSecondsRemaining)}" : "Running")
        </MudChip>
        @if (Snapshot.RainDelayUntil is { } until)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Warning">Rain delay until @until.ToLocalTime().ToString("g")</MudChip>
        }
        <MudChip T="string" Size="Size.Small" Color="Color.Info">Water level @Snapshot.WaterLevelPercent%</MudChip>
        <MudSpacer />
        <MudText Typo="Typo.caption" Class="mud-text-secondary">Updated @Snapshot.TimestampUtc.ToLocalTime().ToString("T")</MudText>
    </MudPaper>

    <MudStack Spacing="2" Class="mb-4" Style="max-width: 820px;">
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudSelect T="int?" @bind-Value="SelectedProgram" Placeholder="Choose a program…"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense="true" Style="max-width: 18rem;">
                @foreach (var p in _enabledPrograms)
                {
                    <MudSelectItem T="int?" Value="@p.Id">@p.Name</MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(_selectedProgramId == 0)"
                       OnClick="RunProgram" StartIcon="@Icons.Material.Filled.PlayArrow">Run program</MudButton>
        </MudStack>

        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            <MudNumericField @bind-Value="_rainDelayMinutes" Label="Rain delay (min)" Min="0"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 9rem;" />
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="SetRainDelay">Set</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ClearRainDelay">Clear</MudButton>
        </MudStack>

        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            @if (Snapshot.Paused)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="Resume"
                           StartIcon="@Icons.Material.Filled.PlayArrow">Resume</MudButton>
            }
            else
            {
                <MudNumericField @bind-Value="_pauseMinutes" Label="Pause (min)" Min="1"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 9rem;" />
                <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="Pause"
                           StartIcon="@Icons.Material.Filled.Pause">Pause</MudButton>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="StopAll"
                       StartIcon="@Icons.Material.Filled.Stop">Stop all</MudButton>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="2">
        @foreach (var zone in Snapshot.Zones)
        {
            <MudItem xs="6" sm="4" md="3" lg="2">
                <MudPaper Class="d-flex flex-column align-center pa-3" Outlined="true"
                          Style="@(CardStyle(zone) + "cursor: pointer;")"
                          @onclick="@(() => OpenRunDialog(zone.ZoneId))">
                    <MudText Typo="Typo.subtitle2" Align="Align.Center">@ZoneName(zone.ZoneId)</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@StateLabel(zone)</MudText>
                    @if ((zone.On || zone.Paused) && zone.SecondsRemaining is { } secs)
                    {
                        <MudText Typo="Typo.h6" Style="font-variant-numeric: tabular-nums;">@Fmt(secs)</MudText>
                    }
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="min-height: 1rem;">@ProgramLabel(zone)</MudText>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>

    <ZoneRunModal Visible="_dialogZoneId is not null"
                  ZoneName="@ZoneName(_dialogZoneId ?? 0)"
                  IsActive="@(DialogZone is { } dz && (dz.On || dz.Queued || dz.Paused))"
                  StateLabel="@(DialogZone is { } dz2 ? StateLabel(dz2) : string.Empty)"
                  OnRun="RunZoneFromDialog"
                  OnStop="StopZoneFromDialog"
                  OnCancel="@(() => _dialogZoneId = null)" />
}

@code {
    private IReadOnlyDictionary<int, string> _zoneNames = new Dictionary<int, string>();
    private IReadOnlyDictionary<int, string> _programNames = new Dictionary<int, string>();
    private IReadOnlyList<(int Id, string Name)> _enabledPrograms = Array.Empty<(int, string)>();

    private int _selectedProgramId;

    // Nullable wrapper so the MudSelect shows its placeholder instead of "0".
    private int? SelectedProgram
    {
        get => _selectedProgramId == 0 ? null : _selectedProgramId;
        set => _selectedProgramId = value ?? 0;
    }

    private int _rainDelayMinutes = 60;
    private int _pauseMinutes = 5;

    // Hardware bit of the zone whose run/stop dialog is open, or null when closed.
    private int? _dialogZoneId;

    // Resolve the live zone status each render so the dialog reflects real-time engine
    // updates (e.g. a zone finishing while the dialog is open).
    private ZoneStatus? DialogZone =>
        _dialogZoneId is { } bit ? Snapshot?.Zones.FirstOrDefault(z => z.ZoneId == bit) : null;

    // The zone to feature at the top: prefer an actively-running zone, then a paused one.
    private ZoneStatus? RunningZone =>
        Snapshot?.Zones.FirstOrDefault(z => z.On) ?? Snapshot?.Zones.FirstOrDefault(z => z.Paused);

    private string RunningBannerStyle => RunningZone switch
    {
        { Paused: true } => "background: rgba(79,158,234,.20); border-color: #4f9eea;",
        { On: true } => "background: rgba(67,160,71,.22); border-color: #43a047;",
        _ => string.Empty,
    };

    protected override async Task OnInitializedAsync()
    {
        var zones = await ZoneRepo.GetAllAsync();
        _zoneNames = zones.ToDictionary(
            z => z.HardwareBit,
            z => string.IsNullOrWhiteSpace(z.Name) ? $"Zone {z.HardwareBit + 1}" : z.Name);
        await LoadProgramsAsync();
    }

    private async Task LoadProgramsAsync()
    {
        var programs = await ProgramRepo.GetAllAsync();
        _programNames = programs.ToDictionary(p => p.Id, p => p.Name);
        _enabledPrograms = programs
            .Where(p => p.Enabled)
            .Select(p => (p.Id, string.IsNullOrWhiteSpace(p.Name) ? $"Program {p.Id}" : p.Name))
            .ToList();
    }

    private string ZoneName(int bit) => _zoneNames.GetValueOrDefault(bit, $"Zone {bit + 1}");

    // Tinted background + border per state, legible on the dark theme.
    private static string CardStyle(ZoneStatus z) => z switch
    {
        { Paused: true } => "background: rgba(79,158,234,.20); border-color: #4f9eea;",
        { On: true } => "background: rgba(67,160,71,.22); border-color: #43a047;",
        { Queued: true } => "background: rgba(251,140,0,.20); border-color: #fb8c00;",
        _ => string.Empty,
    };

    private static string StateLabel(ZoneStatus z) => z.Paused ? "PAUSED" : z.On ? "ON" : z.Queued ? "QUEUED" : "OFF";

    private string ProgramLabel(ZoneStatus z)
    {
        if (z.ProgramId is { } id) return _programNames.GetValueOrDefault(id, $"Program {id}");
        return z.On || z.Paused ? "Manual" : "—";
    }

    private static string Fmt(int seconds) => $"{seconds / 60:D2}:{seconds % 60:D2}";

    private void RunProgram()
    {
        if (_selectedProgramId != 0) ManualRun.RunProgram(_selectedProgramId);
    }

    private void OpenRunDialog(int bit) => _dialogZoneId = bit;

    private void RunZoneFromDialog(int seconds)
    {
        if (_dialogZoneId is { } bit && seconds > 0) ManualRun.RunZoneTimed(bit, seconds);
        _dialogZoneId = null;
    }

    private void StopZoneFromDialog()
    {
        if (_dialogZoneId is { } bit) ManualRun.StopZone(bit);
        _dialogZoneId = null;
    }

    private void SetRainDelay() => ManualRun.SetRainDelay(_rainDelayMinutes);

    private void ClearRainDelay() => ManualRun.SetRainDelay(0);

    private void Pause() => ManualRun.Pause(_pauseMinutes * 60);

    private void Resume() => ManualRun.Resume();

    private void StopAll() => ManualRun.StopAll();
}
