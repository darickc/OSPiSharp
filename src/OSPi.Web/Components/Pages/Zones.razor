@page "/zones"
@rendermode InteractiveServer
@implements IDisposable
@inject IManualRunService ManualRun
@inject IStateHub StateHub

<PageTitle>Zones</PageTitle>

<h1>Zones</h1>
<p class="text-muted">Phase 0 walking skeleton: toggle a zone and watch it flip on the simulated board.</p>

<div class="mb-3">
    <button class="btn btn-danger" @onclick="StopAll">Stop all</button>
    @if (_snapshot is not null)
    {
        <span class="ms-3 text-muted">Last update: @_snapshot.TimestampUtc.ToLocalTime().ToString("T")</span>
    }
</div>

@if (_snapshot is null)
{
    <p><em>Waiting for engine…</em></p>
}
else
{
    <div class="zone-grid">
        @foreach (var zone in _snapshot.Zones)
        {
            <button class="zone-card @(zone.On ? "on" : "off")"
                    @onclick="() => Toggle(zone.ZoneId, !zone.On)">
                <span class="zone-id">Zone @(zone.ZoneId + 1)</span>
                <span class="zone-state">@(zone.On ? "ON" : "OFF")</span>
            </button>
        }
    </div>
}

<style>
    .zone-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
        gap: 0.75rem;
        max-width: 760px;
    }
    .zone-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1rem 0.5rem;
        border-radius: 0.75rem;
        border: 2px solid transparent;
        cursor: pointer;
        font-weight: 600;
        transition: background-color .15s ease, border-color .15s ease;
    }
    .zone-card.off { background: #f1f3f5; color: #495057; border-color: #dee2e6; }
    .zone-card.on  { background: #d3f9d8; color: #2b8a3e; border-color: #2b8a3e; }
    .zone-id { font-size: 0.95rem; }
    .zone-state { font-size: 0.8rem; opacity: 0.8; }
</style>

@code {
    private StatusSnapshot? _snapshot;

    protected override void OnInitialized()
    {
        _snapshot = StateHub.Latest;
        StateHub.SnapshotPublished += OnSnapshot;
    }

    private void OnSnapshot(StatusSnapshot snapshot)
    {
        _snapshot = snapshot;
        _ = InvokeAsync(StateHasChanged);
    }

    private void Toggle(int zoneId, bool on) => ManualRun.Toggle(zoneId, on);

    private void StopAll() => ManualRun.StopAll();

    public void Dispose() => StateHub.SnapshotPublished -= OnSnapshot;
}
