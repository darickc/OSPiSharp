@page "/config/property-map"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IPropertyMapRepository Maps
@inject IPropertyMapImageProcessor ImageProcessor
@inject IZoneRepository ZoneRepo
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Property Map</PageTitle>

<MudText Typo="Typo.h5" GutterBottom="true">Property Map</MudText>

@if (_model is null)
{
    <MudProgressCircular Indeterminate="true" Size="Size.Small" />
}
else
{
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap">
        <MudFileUpload T="IBrowserFile" FilesChanged="OnFileChanged" Accept=".png,.jpg,.jpeg,.webp" Disabled="_busy">
            <CustomContent>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_busy"
                           OnClick="@context.OpenFilePickerAsync"
                           StartIcon="@Icons.Material.Filled.Upload">
                    @(_model.HasImage ? "Replace image" : "Upload image")
                </MudButton>
            </CustomContent>
            <SelectedTemplate />
        </MudFileUpload>
        @if (_busy)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        }
    </MudStack>

    @if (!_model.HasImage)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Upload a photo or diagram of the property, then pick a zone and click the image to drop its pin.
        </MudAlert>
    }
    else
    {
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3 flex-wrap" Style="max-width: 760px;">
            <MudSelect T="int" @bind-Value="_selectedZoneId" Label="Zone" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Dense="true" Style="max-width: 22rem;">
                @foreach (var z in _zones)
                {
                    <MudSelectItem T="int" Value="@z.Id">
                        @ZoneLabel(z) @(_model.HasMarker(z.Id) ? "●" : "")
                    </MudSelectItem>
                }
            </MudSelect>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="@(!_model.HasMarker(_selectedZoneId))"
                       OnClick="RemoveSelected" StartIcon="@Icons.Material.Filled.LocationOff">Remove pin</MudButton>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_busy"
                       OnClick="SaveAsync" StartIcon="@Icons.Material.Filled.Save">Save</MudButton>
        </MudStack>

        <MudText Typo="Typo.caption" Class="mud-text-secondary d-block mb-2">
            Click the image to place the selected zone's pin. Pins use normalized coordinates, so they
            stay put when the map is resized.
        </MudText>

        <div class="map-stage" style="display:flex; justify-content:center; align-items:flex-start; overflow:hidden;">
            <div @ref="_canvasEl" style="@CanvasStyle">
                <img src="@ImageUrl" alt="Property map"
                     style="width:100%; height:100%; display:block; object-fit:fill; border-radius:4px;" />
                @foreach (var m in _model.Markers)
                {
                    <div style="@PinStyle(m, m.ZoneId == _selectedZoneId)">@BitLabel(m.ZoneId)</div>
                }
            </div>
        </div>
    }
}

@code {
    private PropertyMapEditModel? _model;
    private IReadOnlyList<Zone> _zones = Array.Empty<Zone>();
    private Dictionary<int, Zone> _zoneById = new();
    private int _selectedZoneId;
    private bool _busy;

    private const long MaxUploadBytes = 10L * 1024 * 1024;

    // Canvas sizing/placement is handled in JS (PropertyMapEdit.razor.js): it fits the canvas
    // to the available area and reports clicks as normalized coords via PlaceNormalized.
    private ElementReference _canvasEl;
    private IJSObjectReference? _module;
    private DotNetObjectReference<PropertyMapEdit>? _selfRef;
    private bool _fitReady;
    private double _initRatio;

    protected override async Task OnInitializedAsync()
    {
        _zones = (await ZoneRepo.GetAllAsync()).OrderBy(z => z.HardwareBit).ToList();
        _zoneById = _zones.ToDictionary(z => z.Id);
        _selectedZoneId = _zones.FirstOrDefault()?.Id ?? 0;

        _model = PropertyMapEditModel.FromEntity(await Maps.GetAsync());
    }

    // (Re)initialize the fit module when the canvas first appears or the image ratio changes
    // (e.g. a replacement upload with a different shape).
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_model is not { HasImage: true })
        {
            return;
        }

        if (!_fitReady || _initRatio != _model.AspectRatio)
        {
            if (_module is not null)
            {
                try { await _module.InvokeVoidAsync("dispose", _canvasEl); }
                catch (JSDisconnectedException) { }
            }
            _fitReady = true;
            _initRatio = _model.AspectRatio;
            _selfRef ??= DotNetObjectReference.Create(this);
            _module ??= await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Pages/PropertyMapEdit.razor.js");
            await _module.InvokeVoidAsync("init", _canvasEl, _model.AspectRatio, _selfRef);
        }
    }

    private string ImageUrl => $"/property-map/image?v={_model!.ImageHash}";

    // Pre-JS fallback: full-width box at the image's aspect ratio. The fit module overrides
    // width/height with the fitted px size once it loads (explicit px wins).
    private string CanvasStyle =>
        $"position:relative; width:100%; aspect-ratio:{_model!.ImageWidth} / {_model.ImageHeight}; " +
        "overflow:hidden; margin:auto; cursor:crosshair;";

    private async Task OnFileChanged(IBrowserFile? file)
    {
        if (file is null || _model is null)
        {
            return;
        }

        _busy = true;
        try
        {
            // Copy off the circuit into a seekable buffer for ImageSharp.
            using var buffer = new MemoryStream();
            await using (var source = file.OpenReadStream(MaxUploadBytes))
            {
                await source.CopyToAsync(buffer);
            }
            buffer.Position = 0;

            var stored = await ImageProcessor.SaveAsync(buffer);
            await Maps.UpdateImageAsync(stored.RelativePath, stored.Hash, stored.Width, stored.Height);

            _model.ImagePath = stored.RelativePath;
            _model.ImageHash = stored.Hash;
            _model.ImageWidth = stored.Width;
            _model.ImageHeight = stored.Height;
            Snackbar.Add("Image uploaded.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Upload failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    // Invoked from JS with click coords already normalized to [0,1] against the canvas's
    // live rendered size, so placement is accurate at any canvas size / after a resize.
    [JSInvokable]
    public void PlaceNormalized(double x, double y)
    {
        if (_model is null || _selectedZoneId == 0)
        {
            return;
        }

        _model.Place(_selectedZoneId, x, y); // clamps [0,1]/NaN internally
        StateHasChanged();                    // JS-originated callback: re-render to draw the pin
    }

    private void RemoveSelected() => _model?.Remove(_selectedZoneId);

    private async Task SaveAsync()
    {
        if (_model is null)
        {
            return;
        }

        _busy = true;
        try
        {
            await Maps.SaveMarkersAsync(_model.ToEntity());
            Snackbar.Add("Markers saved.", Severity.Success);
        }
        finally
        {
            _busy = false;
        }
    }

    private string ZoneLabel(Zone z) =>
        string.IsNullOrWhiteSpace(z.Name) ? $"Zone {z.HardwareBit + 1}" : $"Zone {z.HardwareBit + 1} — {z.Name}";

    private string BitLabel(int zoneId) =>
        _zoneById.TryGetValue(zoneId, out var z) ? (z.HardwareBit + 1).ToString() : "?";

    private static string PinStyle(PropertyMapEditModel.MarkerRow m, bool selected)
    {
        var color = selected ? "#1976d2" : "#43a047";
        return $"position:absolute; left:{Pct(m.X)}; top:{Pct(m.Y)}; transform:translate(-50%,-50%); " +
               "pointer-events:none; min-width:1.6rem; height:1.6rem; padding:0 .3rem; border-radius:.8rem; " +
               $"background:{color}; color:#fff; font-size:.8rem; font-weight:600; line-height:1.6rem; " +
               "text-align:center; box-shadow:0 0 0 2px rgba(0,0,0,.35); white-space:nowrap;";
    }

    private static string Pct(double v) => $"{(v * 100).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}%";

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("dispose", _canvasEl);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already gone; nothing to clean up.
            }
        }
        _selfRef?.Dispose();
    }
}
