@page "/config/zones/{Id:int}"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@inject IZoneRepository ZoneRepo
@inject IManualRunService Run
@inject NavigationManager Nav

<PageTitle>Edit Zone</PageTitle>

@if (_notFound)
{
    <MudText Typo="Typo.h5" GutterBottom="true">Zone not found</MudText>
    <MudButton Href="config/zones" Variant="Variant.Outlined">Back to zones</MudButton>
}
else if (_model is null)
{
    <MudProgressLinear Indeterminate="true" />
}
else
{
    <MudText Typo="Typo.h5" GutterBottom="true">Edit Zone</MudText>

    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />

        <MudGrid Style="max-width: 640px;">
            <MudItem xs="12" sm="4">
                <MudTextField Value="@_model.HardwareBit.ToString()" Label="Hardware bit" ReadOnly="true"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              HelperText="Fixed hardware index — not editable." T="string" />
            </MudItem>

            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_model.Name" For="@(() => _model.Name)" Label="Name"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <EnumSelect TEnum="ZoneGroup" @bind-Value="_model.Group" Label="Group"
                            LabelFor="DisplayLabels.ZoneGroup" />
            </MudItem>

            <MudItem xs="12">
                <MudCheckBox @bind-Value="_model.BoundToMaster1" Label="Activates master station 1" Color="Color.Primary" Dense="true" />
                <MudCheckBox @bind-Value="_model.BoundToMaster2" Label="Activates master station 2" Color="Color.Primary" Dense="true" />
                <MudCheckBox @bind-Value="_model.Disabled" Label="Disabled (never scheduled or run)" Color="Color.Primary" Dense="true" />
                <MudCheckBox @bind-Value="_model.IgnoreRain" Label="Ignore active rain delay" Color="Color.Primary" Dense="true" />
                <MudCheckBox @bind-Value="_model.IgnoreSensor" Label="Ignore sensor input" Color="Color.Primary" Dense="true" />
            </MudItem>
        </MudGrid>

        <SaveCancelToolbar Busy="_busy" OnCancel="GoBack" />
    </EditForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private ZoneModel? _model;
    private bool _busy;
    private bool _notFound;

    protected override async Task OnInitializedAsync()
    {
        var zone = await ZoneRepo.GetAsync(Id);
        if (zone is null)
        {
            _notFound = true;
            return;
        }

        _model = ZoneModel.FromEntity(zone);
    }

    private async Task SaveAsync()
    {
        if (_model is null)
        {
            return;
        }

        _busy = true;
        try
        {
            await ZoneRepo.UpdateAsync(_model.ToEntity());
            Run.ReloadConfig(); // apply zone changes (disabled, group, rain) to the running engine
            GoBack();
        }
        finally
        {
            _busy = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("config/zones");

    private sealed class ZoneModel
    {
        public int Id { get; set; }

        public int HardwareBit { get; set; }

        [Required(ErrorMessage = "Name is required.")]
        [MaxLength(64, ErrorMessage = "Name must be 64 characters or fewer.")]
        public string Name { get; set; } = string.Empty;

        public ZoneGroup Group { get; set; }

        public bool BoundToMaster1 { get; set; }
        public bool BoundToMaster2 { get; set; }
        public bool Disabled { get; set; }
        public bool IgnoreRain { get; set; }
        public bool IgnoreSensor { get; set; }

        public static ZoneModel FromEntity(Zone z) => new()
        {
            Id = z.Id,
            HardwareBit = z.HardwareBit,
            Name = z.Name,
            Group = z.Group,
            BoundToMaster1 = z.BoundToMaster1,
            BoundToMaster2 = z.BoundToMaster2,
            Disabled = z.Disabled,
            IgnoreRain = z.IgnoreRain,
            IgnoreSensor = z.IgnoreSensor,
        };

        public Zone ToEntity() => new()
        {
            Id = Id,
            HardwareBit = HardwareBit,
            Name = Name.Trim(),
            Group = Group,
            BoundToMaster1 = BoundToMaster1,
            BoundToMaster2 = BoundToMaster2,
            Disabled = Disabled,
            IgnoreRain = IgnoreRain,
            IgnoreSensor = IgnoreSensor,
        };
    }
}
